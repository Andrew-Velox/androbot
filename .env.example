# Copy to .env and fill in real values
# Never commit real tokens.

# Meta Webhook verify token (must match Facebook developer console)
VERIFY_TOKEN=change-me

# Page Access Token from Meta
PAGE_ACCESS_TOKEN=change-me

# Local LLM HTTP endpoint (llama.cpp server)
LLM_URL=http://127.0.0.1:8080/v1/chat/completions

# Optional llama.cpp host/port if using llm-run.sh
LLM_HOST=127.0.0.1
LLM_PORT=8080

# Address to bind the webhook server (0.0.0.0 is required for Termux)
BIND_ADDR=0.0.0.0:3000
